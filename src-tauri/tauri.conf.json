{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Telegram User Activities",
  "version": "0.1.0",
  "identifier": "de.telegram-user-activities",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Telegram User Activities",
        "width": 1000,
        "height": 750,
        "minWidth": 800,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
